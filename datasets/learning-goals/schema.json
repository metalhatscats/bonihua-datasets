{
  "$ref": "#/definitions/learningGoals",
  "definitions": {
    "learningGoals": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9a-zA-Z.-]+)?$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "$ref": "#/definitions/learningGoals/properties/created_at"
        },
        "license": {
          "type": "string"
        },
        "provenance": {
          "type": "string"
        },
        "canonical_url": {
          "type": "string",
          "format": "uri"
        },
        "cite_as_ru": {
          "type": "string"
        },
        "embed_snippets": {
          "type": "object",
          "properties": {
            "html": {
              "type": "string"
            },
            "markdown": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "id": {
          "type": "string",
          "pattern": "^goal:[a-z0-9-]+$"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$"
        },
        "name": {
          "type": "object",
          "properties": {
            "ru": {
              "type": "string",
              "minLength": 1
            },
            "en": {
              "type": "string",
              "minLength": 1
            },
            "zh-Hans": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "ru"
          ],
          "additionalProperties": false
        },
        "desc": {
          "$ref": "#/definitions/learningGoals/properties/name"
        },
        "body": {
          "$ref": "#/definitions/learningGoals/properties/name"
        },
        "when": {
          "$ref": "#/definitions/learningGoals/properties/name"
        },
        "how": {
          "$ref": "#/definitions/learningGoals/properties/name"
        },
        "examples": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/learningGoals/properties/name"
          },
          "minItems": 1,
          "maxItems": 3
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "audience": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "student",
              "tutor",
              "work"
            ]
          }
        },
        "related_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "faq": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": {
                "type": "string",
                "minLength": 1
              },
              "answer": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "question",
              "answer"
            ],
            "additionalProperties": false
          }
        },
        "recommended_level_id": {
          "type": "string",
          "pattern": "^examlevel:[a-z0-9-]+$"
        },
        "related_skill_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^skill:[a-z0-9-]+$"
          }
        },
        "time_frame_weeks": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "outcome": {
          "$ref": "#/definitions/learningGoals/properties/name"
        }
      },
      "required": [
        "version",
        "id",
        "slug",
        "name",
        "desc",
        "when",
        "how",
        "examples",
        "tags",
        "outcome"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
